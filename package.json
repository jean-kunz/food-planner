{
  "name": "food-planner",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "WRANGLER_REGISTRY_PATH=./.wrangler/registry vite dev",
    "dev:local": "WRANGLER_REGISTRY_PATH=./.wrangler/registry vite dev --mode local-supabase",
    "build": "vite build",
    "preview": "vite preview",
    "preview:worker": "WRANGLER_REGISTRY_PATH=./.wrangler/registry vite build && WRANGLER_REGISTRY_PATH=./.wrangler/registry wrangler dev",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "prepare": "svelte-kit sync || echo ''"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.46.0"
  }
}
